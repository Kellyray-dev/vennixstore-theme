{% comment %}
  Renders a VennixStore wishlist heart button.

  Accepts:
  - product: {Object} Product Liquid object (required)

  Usage:
  {% render 'vennix-wishlist-btn', product: card_product %}
{% endcomment %}

{%- if product and product != empty -%}
  {%- assign wl_image = product.featured_media | image_url: width: 400 -%}
  <button
    type="button"
    class="vennix-wishlist-btn"
    data-wishlist-btn
    data-product-id="{{ product.id }}"
    data-product-title="{{ product.title | escape }}"
    data-product-price="{{ product.price | money }}"
    data-product-image="{{ wl_image }}"
    data-product-url="{{ product.url }}"
    aria-pressed="false"
    aria-label="{{ 'products.product.add_to_wishlist' | t: default: 'Add to wishlist' }}"
    title="{{ 'products.product.add_to_wishlist' | t: default: 'Add to wishlist' }}"
  >
    <svg
      class="vennix-wishlist-btn__icon"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      width="22"
      height="22"
      fill="none"
      stroke="currentColor"
      stroke-width="1.8"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      focusable="false"
    >
      <path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.6l-1-1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8z"></path>
    </svg>
  </button>
{%- endif -%}
<button
  class="vennix-wishlist-btn"
  data-wishlist-btn
  data-product-id="{{ product.id }}"
  data-product-title="{{ product.title | escape }}"
  data-product-price="{{ product.price | money }}"
  data-product-image="{{ product.featured_image | image_url: width: 533 }}"
  data-product-url="{{ product.url }}"
  aria-label="Add to wishlist"
>
  <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" fill="none" stroke-width="2">
    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
  </svg>
</button>
