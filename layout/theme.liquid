<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#1a1a2e">

  <!-- Preload critical resources -->
  <link rel="preload" href="{{ 'base.css' | asset_url }}" as="style">
  <link rel="preload" href="{{ 'vennix-logo.svg' | asset_url }}" as="image">

  <title>{{ page_title | escape }}</title>

  {%- render 'meta-tags' -%}

  {{ content_for_header }}

  <!-- Critical CSS -->
  <link rel="stylesheet" href="{{ 'base.css' | asset_url }}" media="print" onload="this.media='all'">
  <noscript><link rel="stylesheet" href="{{ 'base.css' | asset_url }}"></noscript>

  {%- render 'vennix-seo-jsonld' -%}
</head>

<body class="template-{{ template | replace: '.', '-' }}">
  
  <!-- 
    SKIP TO CONTENT LINK (WCAG 2.1 AA)
    Must be the first focusable element in the document.
    Appears visually only when focused via keyboard.
  -->
  <a href="#MainContent" class="skip-to-content-link">
    {{ 'accessibility.skip_to_content' | t }}
  </a>

  {%- section 'announcement-bar' -%}
  {%- section 'header' -%}

  <main id="MainContent" role="main">
    {{ content_for_layout }}
  </main>

  {%- section 'footer' -%}

  <!-- Deferred scripts -->
  <script src="{{ 'global.js' | asset_url }}" defer></script>
  {%- render 'vennix-wishlist' -%} <!-- Example custom deferrable module -->

  {{ content_for_footer }}

  <!-- 
    Skip link styles (production-ready, accessible pattern)
    Add these to assets/base.css or assets/vennix-custom.css for long-term maintainability.
    They are included here for immediate functionality.
  -->
  <style>
    .skip-to-content-link {
      position: absolute;
      top: -100px;
      left: 0;
      z-index: 10000;
      padding: 12px 16px;
      background: #000;
      color: #fff;
      font-size: 14px;
      font-weight: 500;
      text-decoration: none;
      transition: top 0.2s ease;
    }
    .skip-to-content-link:focus {
      top: 0;
      outline: 3px solid #fff;
      outline-offset: 2px;
    }
    /* Ensure it is visible to screen readers but hidden visually until focused */
    .skip-to-content-link:not(:focus) {
      clip: rect(0 0 0 0);
      clip-path: inset(50%);
      height: 1px;
      overflow: hidden;
      position: absolute;
      white-space: nowrap;
      width: 1px;
    }
  </style>

</body>
</html>