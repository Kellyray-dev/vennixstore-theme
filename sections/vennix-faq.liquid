<div class="page-width page-width--narrow section-{{ section.id }}-padding">
  {%- style -%}
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }
    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }
  {%- endstyle -%}

  <h2 class="title title--primary" style="text-align:center;margin-bottom:32px;">{{ section.settings.heading | default: 'Frequently Asked Questions' }}</h2>

  <div class="vennix-faq">
    {%- for block in section.blocks -%}
      <div class="vennix-faq__item" data-vennix-faq-item {{ block.shopify_attributes }}>
        <button class="vennix-faq__question" type="button" data-vennix-faq-toggle>
          <span>{{ block.settings.question }}</span>
          <span class="vennix-faq__icon">+</span>
        </button>
        <div class="vennix-faq__answer rte">
          {{ block.settings.answer }}
        </div>
      </div>
    {%- endfor -%}
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('[data-vennix-faq-toggle]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const item = btn.closest('[data-vennix-faq-item]');
        const isOpen = item.classList.contains('is-open');
        document.querySelectorAll('[data-vennix-faq-item]').forEach((i) => i.classList.remove('is-open'));
        if (!isOpen) item.classList.add('is-open');
      });
    });
  });
</script>

{% schema %}
{
  "name": "FAQ",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What is your return policy?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>We offer a 30-day return policy. Items must be unused with tags attached. Contact us to initiate a return.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        {
          "type": "faq_item",
          "settings": {
            "question": "What is your return policy?",
            "answer": "<p>We offer a 30-day return policy. Items must be unused and in original packaging. To initiate a return, contact our support team with your order number and we'll guide you through the process.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "How long does shipping take?",
            "answer": "<p>Standard shipping takes 3-7 business days within the US. International orders typically arrive within 7-14 business days depending on your location.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Do you ship internationally?",
            "answer": "<p>Yes, we ship to over 50 countries worldwide. International shipping rates and delivery times vary by destination. Duties and taxes may apply depending on your country's regulations.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "How can I track my order?",
            "answer": "<p>Once your order ships, you'll receive an email with a tracking number. You can use this to track your package via the carrier's website, or view your order status in your account dashboard.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Are your products ethically sourced?",
            "answer": "<p>Absolutely. We partner exclusively with manufacturers who uphold fair labor practices and sustainable production methods. Every product in our collection meets our strict ethical standards.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
