{% comment %}
  Main product section with elite CRO enhancements
{% endcomment %}

{%- liquid
  assign product_form_id = 'product-form-' | append: section.id
  assign enable_zoom = section.settings.enable_image_zoom
-%}

<div class="product__wrapper" data-section-id="{{ section.id }}">
  <div class="product__grid grid grid--2-col-tablet">
    <!-- Image Gallery -->
    <div class="product__media-wrapper">
      {%- render 'product-media', product: product, enable_zoom: enable_zoom -%}
    </div>

    <!-- Product Info -->
    <div class="product__info-wrapper">
      {%- render 'product-info', 
        product: product, 
        section_id: section.id, 
        form_id: product_form_id 
      -%}
      
      <!-- Elite Trust Signals -->
      <div class="trust-badges mt-6">
        {%- render 'vennix-trust-badges' -%}
        {%- if product.metafields.custom.reviews_count > 0 -%}
          <p class="text-sm text-green-600">⭐ {{ product.metafields.custom.reviews_count }} reviews • 98% recommend</p>
        {%- endif -%}
      </div>
    </div>
  </div>

  <!-- Additional Details -->
  {%- render 'product-disclosures' -%}
  {%- render 'vennix-size-guide' -%}
</div>

<script>
  // Enhanced JS for smoother UX (add to existing scripts if needed)
  document.addEventListener('DOMContentLoaded', () => {
    // Add subtle success animation on ATC
  });
</script>

<style>
  /* Custom enhancements for CRO */
  .product__info-wrapper { scroll-margin-top: 80px; }
  .trust-badges { border-top: 1px solid #e5e7eb; padding-top: 1.5rem; }
</style>