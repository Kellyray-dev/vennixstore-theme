<div class="page-width section-{{ section.id }}-padding">
  {%- style -%}
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }
    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }
  {%- endstyle -%}

  <h2 class="title title--primary" style="text-align:center;margin-bottom:8px;">{{ section.settings.heading | default: 'Customer Reviews' }}</h2>

  {%- comment -%} Rating summary {%- endcomment -%}
  {%- assign review_blocks = section.blocks | where: 'type', 'review' -%}
  {%- assign total_reviews = review_blocks.size -%}
  {%- assign sum_ratings = 0 -%}
  {%- for block in review_blocks -%}
    {%- assign sum_ratings = sum_ratings | plus: block.settings.rating -%}
  {%- endfor -%}
  {%- if total_reviews > 0 -%}
    {%- assign avg_rating = sum_ratings | times: 1.0 | divided_by: total_reviews -%}
  {%- else -%}
    {%- assign avg_rating = 0 -%}
  {%- endif -%}

  <div style="text-align:center;margin-bottom:40px;">
    <span class="vennix-stars" style="font-size:2rem;">
      {%- for i in (1..5) -%}
        {%- if i <= avg_rating -%}*{%- else -%}☆{%- endif -%}
      {%- endfor -%}
    </span>
    <span style="display:block;font-size:0.9rem;color:#888;margin-top:4px;">{{ avg_rating | round: 1 }} out of 5 — {{ total_reviews }} review{{ total_reviews | pluralize }}</span>
  </div>

  {%- comment -%} Reviews grid {%- endcomment -%}
  {%- if review_blocks.size > 0 -%}
    <div class="vennix-reviews__grid">
      {%- for block in review_blocks -%}
        <div class="vennix-review-card" {{ block.shopify_attributes }}>
          <div class="vennix-stars">
            {%- for i in (1..5) -%}
              {%- if i <= block.settings.rating -%}*{%- else -%}☆{%- endif -%}
            {%- endfor -%}
          </div>
          <div class="vennix-review-card__name">{{ block.settings.reviewer_name }}</div>
          <div class="vennix-review-card__date">{{ block.settings.review_date }}</div>
          <h4 style="font-size:0.95rem;font-weight:600;margin:8px 0 4px;">{{ block.settings.review_title }}</h4>
          <div class="vennix-review-card__body">{{ block.settings.review_body }}</div>
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}

  {%- comment -%} Write a review form {%- endcomment -%}
  <div style="max-width:560px;margin:48px auto 0;">
    <h3 style="font-size:1.3rem;margin-bottom:16px;">Write a Review</h3>
    <form id="vennixReviewForm" style="display:flex;flex-direction:column;gap:16px;">
      <div>
        <label style="display:block;font-size:0.85rem;font-weight:500;margin-bottom:6px;">Your rating</label>
        <div id="vennixStarPicker" class="vennix-star-picker" style="display:flex;gap:4px;cursor:pointer;font-size:1.6rem;color:#ccc;">
          {%- for i in (1..5) -%}
            <span data-star="{{ i }}" style="transition:color 0.15s;">☆</span>
          {%- endfor -%}
        </div>
        <input type="hidden" name="rating" id="vennixRatingValue" value="0">
      </div>
      <div>
        <label for="vennixReviewName" style="display:block;font-size:0.85rem;font-weight:500;margin-bottom:6px;">Your name</label>
        <input type="text" id="vennixReviewName" name="reviewer_name" required style="width:100%;padding:10px 12px;border:1px solid #e5e0d8;border-radius:4px;font-size:0.95rem;">
      </div>
      <div>
        <label for="vennixReviewTitle" style="display:block;font-size:0.85rem;font-weight:500;margin-bottom:6px;">Review title</label>
        <input type="text" id="vennixReviewTitle" name="review_title" style="width:100%;padding:10px 12px;border:1px solid #e5e0d8;border-radius:4px;font-size:0.95rem;">
      </div>
      <div>
        <label for="vennixReviewBody" style="display:block;font-size:0.85rem;font-weight:500;margin-bottom:6px;">Your review</label>
        <textarea id="vennixReviewBody" name="review_body" rows="4" required style="width:100%;padding:10px 12px;border:1px solid #e5e0d8;border-radius:4px;font-size:0.95rem;resize:vertical;"></textarea>
      </div>
      <button type="submit" class="button button--primary" style="align-self:flex-start;">Submit Review</button>
    </form>
    <div id="vennixReviewThankYou" style="display:none;text-align:center;padding:40px 0;">
      <p style="font-size:1.1rem;font-weight:500;">Thank you for your review!</p>
      <p style="color:#888;margin-top:4px;">Your feedback helps us improve.</p>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const starPicker = document.getElementById('vennixStarPicker');
    const ratingInput = document.getElementById('vennixRatingValue');
    if (starPicker) {
      starPicker.addEventListener('click', (e) => {
        const star = e.target.closest('[data-star]');
        if (star) {
          const val = parseInt(star.dataset.star);
          ratingInput.value = val;
          starPicker.querySelectorAll('[data-star]').forEach((s) => {
            s.textContent = parseInt(s.dataset.star) <= val ? '★' : '☆';
            s.style.color = parseInt(s.dataset.star) <= val ? '#f5c518' : '#ccc';
          });
        }
      });
    }
    const form = document.getElementById('vennixReviewForm');
    if (form) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        form.style.display = 'none';
        document.getElementById('vennixReviewThankYou').style.display = 'block';
      });
    }
  });
</script>

{% schema %}
{
  "name": "Reviews",
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "text",
          "id": "reviewer_name",
          "label": "Reviewer name",
          "default": "Customer"
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "text",
          "id": "review_date",
          "label": "Date",
          "default": "Jan 2026"
        },
        {
          "type": "text",
          "id": "review_title",
          "label": "Review title",
          "default": "Great product!"
        },
        {
          "type": "textarea",
          "id": "review_body",
          "label": "Review body",
          "default": "I love this! The quality is outstanding and it arrived quickly."
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Customer Reviews"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
