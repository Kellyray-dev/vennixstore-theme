[
  {
    "name": "theme_info",
    "theme_name": "VennixStore Architectural",
    "theme_version": "1.0.0",
    "theme_author": "VennixStore Project Lead",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "type_heading_font",
        "default": "playfair_display_n4",
        "label": "Heading font"
      },
      {
        "type": "range",
        "id": "heading_scale",
        "min": 100,
        "max": 150,
        "step": 5,
        "unit": "%",
        "label": "Heading scale",
        "default": 110
      },
      {
        "type": "font_picker",
        "id": "type_body_font",
        "default": "inter_n4",
        "label": "Body font"
      },
      {
        "type": "range",
        "id": "body_scale",
        "min": 100,
        "max": 130,
        "step": 5,
        "unit": "%",
        "label": "Body scale",
        "default": 100
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_background",
        "label": "Background",
        "default": "#F9F8F6"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Text",
        "default": "#1A1A1A"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent (Buttons/Sale)",
        "default": "#7A8B81"
      },
      {
        "type": "color",
        "id": "color_border",
        "label": "Borders/Lines",
        "default": "#E5E3DF"
      },
      {
        "type": "color",
        "id": "color_button_text",
        "label": "Button Text",
        "default": "#FFFFFF"
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "range",
        "id": "page_width",
        "min": 1000,
        "max": 1600,
        "step": 50,
        "default": 1400,
        "unit": "px",
        "label": "Page width"
      },
      {
        "type": "range",
        "id": "border_radius",
        "min": 0,
        "max": 20,
        "step": 2,
        "default": 2,
        "unit": "px",
        "label": "Corner radius (Micro)"
      }
    ]
  }
]
